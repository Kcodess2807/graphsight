# Base URL of the TraceRAG FastAPI backend.
# Defaults to http://localhost:8000 when unset.
VITE_API_BASE=http://localhost:8000

# Clerk publishable key (Clerk Dashboard → API Keys → "Publishable key").
# Looks like pk_test_… or pk_live_…. Leave unset to run without auth.
VITE_CLERK_PUBLISHABLE_KEY=
